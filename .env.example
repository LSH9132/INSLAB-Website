# Admin login password (use a strong password)
ADMIN_PASSWORD=change-me

# Secret key for signing session cookies (random string, changing invalidates all sessions)
# Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-random-64-char-string

# Domain name for SSL certificate (production only)
DOMAIN=example.com

# Email for Let's Encrypt certificate notifications
CERTBOT_EMAIL=admin@example.com
