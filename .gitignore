# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
/-*

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.stitch/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# Docker bind mount data (images, builds, site output are not tracked)
docker-data/admin/images/
docker-data/builder/
docker-data/site/

# Backups
backups/

# typescript
*.tsbuildinfo
next-env.d.ts
